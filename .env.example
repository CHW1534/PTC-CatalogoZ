# Docker Compose Environment Variables

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ptcretail

# Backend
NODE_ENV=production
PORT=3000
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ptcretail
RUN_SEED=true

# Frontend (build arg)
VITE_API_URL=/api
